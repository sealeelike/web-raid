#!/usr/bin/env bash
# backupctl - 单机增量加密备份系统主 CLI
# 用法见 `backupctl help`
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./lib.sh
source "${SCRIPT_DIR}/lib.sh"

usage() {
    cat <<'EOF'
用法: backupctl <命令> [参数]

target 管理:
  target add              交互式粘贴 VPS 一键脚本输出的凭据，添加一个备份目标
  target list              列出所有已配置的备份目标
  target remove <name>     删除一个备份目标（本地配置，不影响远端仓库数据）

path 管理:
  path add [目录]          添加一个备份源目录（不填默认当前目录）
  path remove <目录>       从备份源中移除一个目录
  path list                列出所有已配置的备份源目录

执行:
  run [--target <name>] [--force] [--path <目录>]
                           对指定或全部已启用 target 跑一次备份，成功后自动清理旧快照
                           （--force 供事件触发器/定时器等自动化调用时跳过去抖判断用，
                           手动执行不需要加；--path 只备份 paths.conf 里的这一个目录，
                           不加则备份全部——不同目录的保留策略天然独立，互不影响）
                           退出码：0=成功，1=备份/清理失败，75=锁被占用本次跳过（可重试）

服务管理（zero 手动改配置：systemd unit 里的绝对路径由本命令自动填入）:
  service install          安装并启用 systemd/ 目录下的所有 unit（写入 ~/.config/systemd/user/），开机/登录后自动运行
  service status            查看已安装 unit 的运行状态
  service stop              暂停正在运行的后台监控（不删配置、不取消开机自启，随时可以 start 恢复）
  service start             恢复被 service stop 暂停的后台监控
  service uninstall         彻底停止并卸载已安装的 unit（取消开机自启，删除 systemd 配置文件）

  help                     显示本帮助
EOF
}

# ===========================================================================
# target add
# ===========================================================================
cmd_target_add() {
    echo "粘贴 VPS 一键脚本运行结束后打印的那一整行凭据（base64），回车确认："
    read -rp "> " BLOB
    [[ -n "$BLOB" ]] || die "凭据不能为空"

    local parsed
    parsed="$(echo "$BLOB" | base64 -d 2>/dev/null)" || die "凭据解析失败，请确认完整复制了那一整行"
    local host port user pass cert_b64
    host="$(echo "$parsed" | python3 -c 'import json,sys; print(json.load(sys.stdin)["host"])' 2>/dev/null)" || die "凭据格式不正确"
    port="$(echo "$parsed" | python3 -c 'import json,sys; print(json.load(sys.stdin)["port"])')"
    user="$(echo "$parsed" | python3 -c 'import json,sys; print(json.load(sys.stdin)["user"])')"
    pass="$(echo "$parsed" | python3 -c 'import json,sys; print(json.load(sys.stdin)["pass"])')"
    cert_b64="$(echo "$parsed" | python3 -c 'import json,sys; print(json.load(sys.stdin)["cert_pem_b64"])')"

    ok "解析成功：${host}:${port}，用户 ${user}"

    local default_name="vps-${host##*.}"
    read -rp "给这个备份目标起个名字（直接回车用默认 [${default_name}]): " name
    name="${name:-$default_name}"
    [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "名字只能包含字母/数字/下划线/短横线"
    [[ -f "${TARGETS_DIR}/${name}.env" ]] && die "target '${name}' 已存在，先 backupctl target remove ${name} 再重新添加"

    echo "$cert_b64" | base64 -d > "${TARGETS_DIR}/${name}.crt"

    local repo_pass
    read -rp "设置这个仓库的加密密码（直接回车自动生成强密码并保存在本地，一旦生成请勿丢失）: " repo_pass
    if [[ -z "$repo_pass" ]]; then
        repo_pass="$(openssl rand -base64 32)"
        info "已自动生成仓库密码（保存在 config/targets/${name}.pass，请自行做好这台机器的系统备份/密钥托管）"
    fi
    umask 077
    printf '%s' "$repo_pass" > "${TARGETS_DIR}/${name}.pass"
    chmod 600 "${TARGETS_DIR}/${name}.pass"

    cat > "${TARGETS_DIR}/${name}.env" <<EOF
TARGET_NAME=${name}
TARGET_HOST=${host}
TARGET_PORT=${port}
TARGET_USER=${user}
TARGET_PASS=${pass}
ENABLED=true
# 每次成功备份后，实时仓库只保留最近这么多份快照（历史版本由 VPS 侧每日归档负责，见 doc/00-architecture.md）
KEEP_LAST=1
# 上传限速 KiB/s，留空表示不限速
LIMIT_UPLOAD_KBPS=
EOF
    chmod 600 "${TARGETS_DIR}/${name}.env"

    local restic_bin
    restic_bin="$(resolve_restic)"

    load_target "$name"
    export_restic_env
    info "正在初始化 restic 仓库 ..."
    if "$restic_bin" init; then
        ok "target '${name}' 添加完成，仓库已初始化"
        log_line "target add: ${name} (${host}:${port}) 初始化成功"
    else
        rm -f "${TARGETS_DIR}/${name}.env" "${TARGETS_DIR}/${name}.crt" "${TARGETS_DIR}/${name}.pass"
        die "restic init 失败，已回滚本地配置，请检查网络/凭据后重试"
    fi
}

cmd_target_list() {
    local names
    names="$(list_targets)"
    if [[ -z "$names" ]]; then
        info "还没有配置任何备份目标，用 'backupctl target add' 添加一个"
        return 0
    fi
    printf '%-20s %-25s %-15s %-8s\n' "名称" "地址" "用户" "启用"
    while IFS= read -r name; do
        load_target "$name"
        printf '%-20s %-25s %-15s %-8s\n' "$TARGET_NAME" "${TARGET_HOST}:${TARGET_PORT}" "$TARGET_USER" "$ENABLED"
    done <<< "$names"
}

cmd_target_remove() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "用法: backupctl target remove <name>"
    [[ -f "${TARGETS_DIR}/${name}.env" ]] || die "target 不存在: ${name}"
    warn "这只会删除本机的配置（凭据/证书/仓库密码），不会删除远端 VPS 上已有的备份数据"
    read -rp "确认删除 target '${name}' 的本地配置？[y/N]: " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        rm -f "${TARGETS_DIR}/${name}.env" "${TARGETS_DIR}/${name}.crt" "${TARGETS_DIR}/${name}.pass"
        ok "已删除 target '${name}' 的本地配置"
        log_line "target remove: ${name}"
    else
        info "已取消"
    fi
}

# ===========================================================================
# path 管理
# ===========================================================================
cmd_path_add() {
    local dir="${1:-$(pwd)}"
    dir="$(realpath -e "$dir" 2>/dev/null)" || die "目录不存在: ${1:-$(pwd)}"
    [[ -d "$dir" ]] || die "不是一个目录: $dir"
    touch "$PATHS_CONF"
    if grep -qxF "$dir" "$PATHS_CONF"; then
        info "该目录已在备份列表中: $dir"
        return 0
    fi
    echo "$dir" >> "$PATHS_CONF"
    ok "已添加备份源目录: $dir"
    log_line "path add: ${dir}"
}

cmd_path_remove() {
    local dir="${1:-}"
    [[ -n "$dir" ]] || die "用法: backupctl path remove <目录>"
    dir="$(realpath -m "$dir")"
    [[ -f "$PATHS_CONF" ]] && grep -qxF "$dir" "$PATHS_CONF" || die "该目录不在备份列表中: $dir"
    # grep -v 在"删的是最后一行"时会因为没有匹配输出而返回状态 1，这里是预期情况，不能让 set -e 打断
    grep -vxF "$dir" "$PATHS_CONF" > "${PATHS_CONF}.tmp" || true
    mv "${PATHS_CONF}.tmp" "$PATHS_CONF"
    ok "已移除备份源目录: $dir"
    log_line "path remove: ${dir}"
}

cmd_path_list() {
    if [[ ! -s "$PATHS_CONF" ]]; then
        info "还没有配置任何备份源目录，用 'backupctl path add [目录]' 添加"
        return 0
    fi
    cat -n "$PATHS_CONF"
}

# ===========================================================================
# run：实际执行备份
# ===========================================================================

# 单个 target 的备份 + 清理，返回非 0 表示这个 target 失败（不中断其他 target）
# only_path 非空时只备份这一个目录（不读整个 paths.conf）——配合 restic forget 默认按
# host,paths 分组保留策略的行为，每个目录的保留策略天然互不影响，不需要"大家凑在一起才备份"
run_one_target() {
    local name="$1" restic_bin="$2" only_path="${3:-}"
    load_target "$name"
    if [[ "$ENABLED" != "true" ]]; then
        info "target '${name}' 已禁用，跳过"
        return 0
    fi
    export_restic_env

    local paths=()
    if [[ -n "$only_path" ]]; then
        paths=("$only_path")
    else
        while IFS= read -r p; do
            [[ -n "$p" ]] && paths+=("$p")
        done < "$PATHS_CONF"
    fi

    info "[${name}] 开始备份 ${#paths[@]} 个目录 ..."
    # 本命令已经用 flock 保证不会有第二个 backupctl run 并发执行，
    # 所以这里可以放心无条件清理远端可能残留的 stale lock（上次运行被 kill -9/断电中断的情况）
    "$restic_bin" unlock >/dev/null 2>&1 || true

    local limit_args=()
    [[ -n "${LIMIT_UPLOAD_KBPS:-}" ]] && limit_args=(--limit-upload "$LIMIT_UPLOAD_KBPS")

    if nice -n 19 ionice -c3 "$restic_bin" backup "${paths[@]}" "${limit_args[@]}"; then
        ok "[${name}] 备份成功"
        log_line "run: ${name} 备份成功"
        date '+%Y-%m-%d %H:%M:%S' > "${VAR_DIR}/last-success.${name}"
        # 不管这次是 watcher/ticker 触发的还是手动跑的，只要这个目录被成功备份了，
        # 就清零它自己的累计开机 tick 计数——backup-ticker.sh 的兜底阈值只针对
        # "确实一直没成功过"的目录，不应该在已经成功之后还继续计
        local p
        for p in "${paths[@]}"; do
            echo 0 > "${VAR_DIR}/uptime-ticks.$(path_slug "$p")" 2>/dev/null || true
        done

        info "[${name}] 清理旧快照 (keep-last ${KEEP_LAST:-1}) ..."
        if nice -n 19 ionice -c3 "$restic_bin" forget --keep-last "${KEEP_LAST:-1}" --prune; then
            ok "[${name}] 快照清理完成"
            log_line "run: ${name} forget --prune 完成"
        else
            warn "[${name}] forget --prune 失败（不影响本次已完成的备份，下次运行会重试）"
            log_line "run: ${name} forget --prune 失败"
        fi
        return 0
    else
        err "[${name}] 备份失败"
        log_line "run: ${name} 备份失败"
        return 1
    fi
}

# 锁被占用时的退出码：不用 0（那样调用方会以为"这次真的什么都不用做了"），
# 也不用 1（那样看起来像备份失败），用一个专门的哨兵值让自动化调用方（watcher/ticker）
# 能区分出"这次没跑成，稍后应该重试"，而不是把"跳过"误当成"成功"从而清空自己的去抖状态
EX_LOCK_BUSY=75

cmd_run() {
    local only_target="" force=0 only_path=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target) only_target="${2:-}"; [[ -n "$only_target" ]] || die "--target 需要指定 target 名称"; shift 2 ;;
            --force)  force=1; shift ;;
            --path)   only_path="${2:-}"; [[ -n "$only_path" ]] || die "--path 需要指定目录"; shift 2 ;;
            *) die "未知参数: $1" ;;
        esac
    done
    # --force 目前只是预留给模块 5/6 的自动触发脚本用来跳过外部去抖判断，
    # run 本身不做任何"要不要跑"的前置判断，调不调用这条命令由触发脚本自己决定
    : "$force"

    if [[ -n "$only_path" ]]; then
        only_path="$(realpath -m "$only_path")"
        [[ -f "$PATHS_CONF" ]] && grep -qxF "$only_path" "$PATHS_CONF" || die "--path 指定的目录不在 paths.conf 里: ${only_path}"
    fi

    local lockfile="${VAR_DIR}/backup.lock"
    exec 200>"$lockfile"
    if ! flock -n 200; then
        info "已有 backupctl run 正在执行，本次跳过"
        return "$EX_LOCK_BUSY"
    fi

    local names
    if [[ -n "$only_target" ]]; then
        [[ -f "${TARGETS_DIR}/${only_target}.env" ]] || die "target 不存在: ${only_target}"
        names="$only_target"
    else
        names="$(list_targets)"
    fi
    [[ -n "$names" ]] || { warn "没有配置任何备份目标，先用 'backupctl target add' 添加"; return 0; }
    [[ -s "$PATHS_CONF" ]] || { warn "没有配置任何备份源目录，先用 'backupctl path add' 添加"; return 0; }

    local restic_bin
    restic_bin="$(resolve_restic)"

    local overall_failed=0
    while IFS= read -r name; do
        run_one_target "$name" "$restic_bin" "$only_path" || overall_failed=1
    done <<< "$names"

    [[ $overall_failed -eq 0 ]] || return 1
}

# ===========================================================================
# service：安装/管理 systemd --user unit
# ===========================================================================
SYSTEMD_SRC_DIR="${BACKUP_HOME}/systemd"
SYSTEMD_USER_DIR="${HOME}/.config/systemd/user"

# 列出 systemd/ 目录下所有 unit 模板文件的文件名（.service/.timer）
list_unit_templates() {
    find "$SYSTEMD_SRC_DIR" -maxdepth 1 -type f \( -name '*.service' -o -name '*.timer' \) -printf '%f\n' 2>/dev/null | sort
}

cmd_service_install() {
    command -v systemctl >/dev/null 2>&1 || die "未检测到 systemctl，当前系统不支持 systemd --user"

    local units
    units="$(list_unit_templates)"
    [[ -n "$units" ]] || die "systemd/ 目录下没有任何 unit 模板"

    mkdir -p "$SYSTEMD_USER_DIR"

    local name
    while IFS= read -r name; do
        # 用真实的 BACKUP_HOME 绝对路径替换模板里的占位符，写到 ~/.config/systemd/user/，
        # 这样用户不需要手动打开 unit 文件改任何路径
        sed "s#__BACKUP_HOME__#${BACKUP_HOME}#g" "${SYSTEMD_SRC_DIR}/${name}" > "${SYSTEMD_USER_DIR}/${name}"
        ok "已写入 ${SYSTEMD_USER_DIR}/${name}"
    done <<< "$units"

    systemctl --user daemon-reload

    while IFS= read -r name; do
        # .timer 只需要启用自己；对应的 .service 走 timer 触发，不需要 --now 常驻启动
        if [[ "$name" == *.timer ]]; then
            systemctl --user enable --now "$name"
        elif [[ "$name" == *.service ]]; then
            # 如果同名 .timer 也在这批 unit 里，说明这个 .service 是给 timer 用的 oneshot，
            # 不需要单独 enable --now（timer 会负责触发它）
            local base="${name%.service}"
            if printf '%s\n' "$units" | grep -qxF "${base}.timer"; then
                info "跳过单独启动 ${name}（由 ${base}.timer 负责触发）"
            else
                systemctl --user enable --now "$name"
            fi
        fi
    done <<< "$units"

    ok "服务安装完成"
    log_line "service install: $(echo "$units" | tr '\n' ' ')"
    warn "注意：systemd --user 服务默认只在你登录桌面会话期间运行。如果希望笔记本合盖/注销后台仍继续跑，"
    warn "可执行: loginctl enable-linger \$USER（一次性设置，本命令不会自动帮你执行）"
}

cmd_service_status() {
    local units
    units="$(list_unit_templates)"
    [[ -n "$units" ]] || die "systemd/ 目录下没有任何 unit 模板"
    while IFS= read -r name; do
        echo "=== ${name} ==="
        systemctl --user status "$name" --no-pager -l || true
        echo
    done <<< "$units"
}

cmd_service_uninstall() {
    local units
    units="$(list_unit_templates)"
    [[ -n "$units" ]] || die "systemd/ 目录下没有任何 unit 模板"
    while IFS= read -r name; do
        if [[ -f "${SYSTEMD_USER_DIR}/${name}" ]]; then
            systemctl --user disable --now "$name" 2>/dev/null || true
            rm -f "${SYSTEMD_USER_DIR}/${name}"
            ok "已卸载 ${name}"
        fi
    done <<< "$units"
    systemctl --user daemon-reload
    log_line "service uninstall: $(echo "$units" | tr '\n' ' ')"
}

# 只暂停正在运行的服务，不删配置文件、不取消开机自启——下次 start 或重新登录/重启后还会按原样恢复
cmd_service_stop() {
    local units
    units="$(list_unit_templates)"
    [[ -n "$units" ]] || die "systemd/ 目录下没有任何 unit 模板"
    local found=0
    while IFS= read -r name; do
        if [[ -f "${SYSTEMD_USER_DIR}/${name}" ]]; then
            found=1
            systemctl --user stop "$name" 2>/dev/null || true
            ok "已停止 ${name}"
        fi
    done <<< "$units"
    [[ $found -eq 1 ]] || die "还没有安装任何服务，先执行 'backupctl service install'"
    log_line "service stop: $(echo "$units" | tr '\n' ' ')"
}

# 恢复被 service stop 暂停的服务（不重新写配置，只是重新启动已安装的 unit）
cmd_service_start() {
    local units
    units="$(list_unit_templates)"
    [[ -n "$units" ]] || die "systemd/ 目录下没有任何 unit 模板"
    local found=0
    while IFS= read -r name; do
        if [[ -f "${SYSTEMD_USER_DIR}/${name}" ]]; then
            found=1
            systemctl --user start "$name" 2>/dev/null || true
            ok "已启动 ${name}"
        fi
    done <<< "$units"
    [[ $found -eq 1 ]] || die "还没有安装任何服务，先执行 'backupctl service install'"
    log_line "service start: $(echo "$units" | tr '\n' ' ')"
}

# ===========================================================================
# 分发
# ===========================================================================
main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        target)
            local sub="${1:-}"; shift || true
            case "$sub" in
                add)    cmd_target_add ;;
                list)   cmd_target_list ;;
                remove) cmd_target_remove "${1:-}" ;;
                *) die "未知子命令: target ${sub}（可用: add/list/remove）" ;;
            esac
            ;;
        path)
            local sub="${1:-}"; shift || true
            case "$sub" in
                add)    cmd_path_add "${1:-}" ;;
                remove) cmd_path_remove "${1:-}" ;;
                list)   cmd_path_list ;;
                *) die "未知子命令: path ${sub}（可用: add/remove/list）" ;;
            esac
            ;;
        run) cmd_run "$@" ;;
        service)
            local sub="${1:-}"; shift || true
            case "$sub" in
                install)   cmd_service_install ;;
                status)    cmd_service_status ;;
                stop)      cmd_service_stop ;;
                start)     cmd_service_start ;;
                uninstall) cmd_service_uninstall ;;
                *) die "未知子命令: service ${sub}（可用: install/status/stop/start/uninstall）" ;;
            esac
            ;;
        help|-h|--help) usage ;;
        *) usage; [[ "$cmd" == "help" ]] || exit 1 ;;
    esac
}

main "$@"
