# 运行时状态与敏感数据不入库
var/log/*.log
var/*.lock
var/last-success.*
var/uptime-ticks.*
var/success-log*

# 每个 target 的凭据/密码/证书是敏感数据
config/targets/*.env
config/targets/*.crt
config/targets/*.pem
config/paths.conf

# restic 客户端二进制（无 apt/root 权限时由 backupctl 自动下载的本地兜底副本），体积大不入库
bin/.restic-local

# 保留目录结构但不保留占位文件之外的内容
!.gitkeep
